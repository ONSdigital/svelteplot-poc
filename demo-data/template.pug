-// Metadata for SEO and analytics
section.Meta
    prop.title How the population has changed in your area - ONS
    prop.description Demographic trends in local authorities within the UK
    prop.contentTitle Title for google analytics
    prop.releaseDate 2023-01-01
    prop.lastUpdated 2023-01-01
    prop.outputSeries slugforoutputseries
    prop.contentType robo-journalism

if !place
    section.Header
        prop.title How the population has changed in your area
        prop.label Select a local authority

else
    section.Header
        prop.title How the population has changed #{place.getName("in")}
        prop.label Select another local authority

    //- section.Highlight
    //-     p In 2020, #{place.getName("the")} was the #{places.filterBy("parentcd", place.parentcd).getRank(place, "p2047").toWords("ordinal", {keepFirst: false})} largest local authority in #{lookup[place.parentcd].getName("the")}, with a total population of #{place.p2047.format()}.
    
    section#chart-bar.Chart
        prop.chartType bar
        prop.variant simple
        prop.data= places.filterBy("parentcd", place.parentcd).toData({y: "areanm", x: ["p2047"]})
        prop.ySort descending
        prop.xFormat ,.0f
        prop.dataLabels true
        prop.highlighted= place.areanm

    section#chart-bar.Chart
        prop.chartType bar
        prop.variant clustered
        prop.data= place.toData({y: "areanm", x: ["age0_15_25yrchange", "age16_24_25yrchange", "age25_49_25yrchange", "age50_64_25yrchange", "age65_25yrchange"], z: ["Aged under 16", "Aged 16 to 24", "Aged 25 to 49", "Aged 50 to 64", "Aged 65 and over"]})
        prop.xFormat ,.1%
        prop.dataLabels true
        prop.zKey z

    section#chart-bar.Chart
        prop.chartType bar
        prop.variant stacked
        prop.data= place.toData({y: ["2022","2022","2022","2022","2022","2032","2032","2032","2032","2032","2042","2042","2042","2042","2042"], x: ["prop_age0_15_2022", "prop_age16_24_2022","prop_age25_49_2022","prop_age50_64_2022","prop_age65_2022","prop_age0_15_2032", "prop_age16_24_2032","prop_age25_49_2032","prop_age50_64_2032","prop_age65_2032","prop_age0_15_2042", "prop_age16_24_2042","prop_age25_49_2042","prop_age50_64_2042","prop_age65_2042"], z: ["Aged under 16", "Aged 16 to 24", "Aged 25 to 49", "Aged 50 to 64", "Aged 65 and over","Aged under 16", "Aged 16 to 24", "Aged 25 to 49", "Aged 50 to 64", "Aged 65 and over","Aged under 16", "Aged 16 to 24", "Aged 25 to 49", "Aged 50 to 64", "Aged 65 and over"]})
        prop.xFormat ,.1%
        prop.zKey z
        prop.highlighted= place.areanm
        prop.dataLabels true

    section#arrow-chart.Chart
        prop.chartType dot
        prop.variant arrow
        prop.data= places.filterBy("parentcd", place.parentcd).toData({y: "areanm", x: ["prop_age25_49_2022","prop_age25_49_2047"], z: ["2022", "2047"]})
        prop.xFormat .1%
        prop.dataLabels true
        prop.xDomain data
        prop.ySort descending
        prop.ySortKey difference
        prop.highlighted= place.areanm
        prop.xAxisLabel Proportion of population
        prop.yAxisLabel Upper Tier Local Authority

