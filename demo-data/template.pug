    section#beeswarm.Chart
        prop.chartType beeswarm
        prop.variant force
        prop.data= places.filter((d) => d.areanm != "City of London").toData({y: ["10 year population change","25 year population change"], x: ["change10yr","change25yr"], z: "areanm"})
        prop.highlighted= place.areanm
        prop.xFormat .1%
        prop.seriesHeight= 150
